{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the English testing chatbot.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique user ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "assessedLevel": {
          "type": "string",
          "description": "The user's assessed English level (e.g., A1, B2, C1).",
          "enum": ["A1", "A2", "B1", "B2", "C1", "C2", "Pending"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created."
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message between the user and the bot.",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["user", "model", "system"],
          "description": "The role of the message sender."
        },
        "content": {
          "type": "string",
          "description": "The text content of the message."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        }
      },
      "required": ["role", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores chat messages for a specific user."
    }
  }
}
